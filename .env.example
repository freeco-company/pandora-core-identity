APP_NAME="Pandora Core Identity"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8001

APP_LOCALE=zh_TW
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_TW

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# === Database (MariaDB 10.11+，集團主棧) =====================================
DB_CONNECTION=mariadb
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pandora_core_identity
DB_USERNAME=root
DB_PASSWORD=

# === Cache / Session / Queue =================================================
# 預設先 database，CI 用 array；prod 上 Redis（ADR-006 ElastiCache）
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# === Redis (token blacklist / rate limiting / outbox) ========================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# === JWT (RS256) - issue #3 設定 =============================================
# 啟動時跑 php artisan pandora:jwt:keygen 產生 dev 用 keypair（issue #3 提供）
JWT_PRIVATE_KEY_PATH=storage/keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=storage/keys/jwt-public.pem
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
JWT_ISSUER=pandora-core
JWT_AUDIENCE_DEFAULT=fp

# === Internal endpoint shared secret (for #9 shadow-mirror) =================
# 母艦呼叫 platform internal endpoints 時帶 X-Pandora-Internal-Secret header
PANDORA_INTERNAL_SECRET=dev-secret-change-me

# === Identity Webhook Publisher (ADR-007 Phase 1, issue #10) =================
# kill switch；dev 預設關，scheduled command 仍跑但空轉
IDENTITY_PUBLISHER_ENABLED=false

# Consumer registry (env per consumer)
# 每個 consumer 必須三個都設好（enabled=true / url / secret）才會被 active；
# 任一缺失即 skip，避免半成品 config 灌一堆 dead_letter
IDENTITY_CONSUMER_PANDORA_JS_STORE_ENABLED=false
IDENTITY_CONSUMER_PANDORA_JS_STORE_URL=
IDENTITY_CONSUMER_PANDORA_JS_STORE_SECRET=

IDENTITY_CONSUMER_DODO_ENABLED=false
IDENTITY_CONSUMER_DODO_URL=
IDENTITY_CONSUMER_DODO_SECRET=

# === OAuth providers (issue #4 設定) ==========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/v1/auth/oauth/google/callback"

LINE_CLIENT_ID=
LINE_CLIENT_SECRET=
LINE_REDIRECT_URI="${APP_URL}/v1/auth/oauth/line/callback"

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_REDIRECT_URI="${APP_URL}/v1/auth/oauth/apple/callback"

# === Mail =====================================================================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@pandora.fairy"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
